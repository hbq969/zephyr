# LightRAG 环境配置模板
# cp .env.lightrag.example .env.lightrag 并填入真实值

# LLM 配置
export LIGHTRAG_LLM_BASE_URL=https://your-llm-service/v1
export LIGHTRAG_LLM_MODEL=your-llm-model
export LIGHTRAG_LLM_API_KEY=sk-your-key

# Embedding 配置
export LIGHTRAG_EMBED_BASE_URL=https://your-embed-service/v1
export LIGHTRAG_EMBED_MODEL=your-embed-model
export LIGHTRAG_EMBED_API_KEY=your-embed-key
export LIGHTRAG_EMBED_DIM=1024

# 数据目录
export LIGHTRAG_DATA_DIR=~/.zephyr/lightrag
